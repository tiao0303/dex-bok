&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#66d9ef"&gt;function&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;vote&lt;/span&gt;(&lt;span style="color:#66d9ef"&gt;uint256&lt;/span&gt; proposalId, &lt;span style="color:#66d9ef"&gt;bool&lt;/span&gt; support) &lt;span style="color:#66d9ef"&gt;public&lt;/span&gt; {
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; require(block.timestamp &lt;span style="color:#f92672"&gt;-&lt;/span&gt; token.lockTime(msg.sender) &lt;span style="color:#f92672"&gt;&amp;gt;=&lt;/span&gt; &lt;span style="color:#ae81ff"&gt;7&lt;/span&gt; &lt;span style="color:#66d9ef"&gt;days&lt;/span&gt;, &lt;span style="color:#e6db74"&gt;&amp;#34;Tokens too new&amp;#34;&lt;/span&gt;);
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; ...
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;}
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#75715e"&gt;// 方法 2：时间锁
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#66d9ef"&gt;function&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;executeProposal&lt;/span&gt;(&lt;span style="color:#66d9ef"&gt;uint256&lt;/span&gt; proposalId) &lt;span style="color:#66d9ef"&gt;public&lt;/span&gt; {
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; require(block.timestamp &lt;span style="color:#f92672"&gt;&amp;gt;=&lt;/span&gt; proposal.timelock, &lt;span style="color:#e6db74"&gt;&amp;#34;Timelock not passed&amp;#34;&lt;/span&gt;);
