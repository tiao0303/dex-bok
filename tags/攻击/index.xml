&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#75715e"&gt;// 方法 3：限制闪电贷
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#66d9ef"&gt;function&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;flashLoan&lt;/span&gt;(&lt;span style="color:#66d9ef"&gt;uint&lt;/span&gt; amount) &lt;span style="color:#66d9ef"&gt;public&lt;/span&gt; {
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; require(msg.sender &lt;span style="color:#f92672"&gt;!=&lt;/span&gt; contractAddress, &lt;span style="color:#e6db74"&gt;&amp;#34;No flash loan attacks&amp;#34;&lt;/span&gt;);
