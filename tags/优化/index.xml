 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;Optimism&lt;/td&gt;
 &lt;td&gt;$0.8-3&lt;/td&gt;
 &lt;td&gt;94%+&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;Polygon&lt;/td&gt;
 &lt;td&gt;$0.02-0.1&lt;/td&gt;
 &lt;td&gt;99%+ ✅&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;
