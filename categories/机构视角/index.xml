 &lt;td&gt;高频/期权&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;GSR&lt;/td&gt;
 &lt;td&gt;$50 亿+&lt;/td&gt;
 &lt;td&gt;机构服务&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;Amberdata&lt;/td&gt;
 &lt;td&gt;$20 亿+&lt;/td&gt;
 &lt;td&gt;数据分析&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;Alameda(已倒闭)&lt;/td&gt;
